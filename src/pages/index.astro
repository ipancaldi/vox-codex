---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const events = (await getCollection('events'))
  .filter((event) => event.data.status === 'upcoming')
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const featuredEvent = events.find((event) => event.data.featured) ?? events[0];
const stories = await getCollection('stories');
---

<BaseLayout title="A welcoming community choir in Holloway">
  <section class="hero">
    <div class="hero__copy">
      <div class="hero__statement">
        <div>
          <h1>Stop wondering about it.</h1>
          <p>Warm, ambitious community singing in Holloway, open to new voices and built around belonging.</p>
        </div>
        <div class="hero__script" aria-label="Start making it.">
          <span>Start</span>
          <span>Making it.</span>
        </div>
      </div>
    </div>
    <div class="hero__media">
      <img src="/images/community-choir.jpg" alt="Illustration of a diverse community choir singing together" />
      <a class="media-control media-control--left" href="/join/" aria-label="Join VOX">▶</a>
      <a class="media-control media-control--right" href="/events/" aria-label="See events">♪</a>
    </div>
  </section>

  <section class="case-section">
    <div class="mini-heading">
      <p class="eyebrow">Start here</p>
      <a href="/events/">View all</a>
    </div>
    <div class="case-grid">
      <article class="info-card">
        <img src="/images/community-choir.jpg" alt="" />
        <h3>Join the choir</h3>
        <p>Come to an open rehearsal, meet the group, and find your voice at your own pace.</p>
      </article>
      <article class="info-card">
        <img src="/images/beach-boys.jpg" alt="" />
        <h3>Come to events</h3>
        <p>Find upcoming concerts, open rehearsals, community performances, and seasonal projects.</p>
      </article>
      <article class="info-card">
        <img src="/images/vox_logo.svg" alt="" />
        <h3>Support the work</h3>
        <p>Buy merch, donate, or help us keep ambitious music open to more singers.</p>
      </article>
    </div>
  </section>

  {featuredEvent && (
    <section class="feature-band">
      <div class="feature-band__image">
        <img src={featuredEvent.data.image} alt="" />
      </div>
      <div class="feature-band__copy">
        <p class="eyebrow">Featured event</p>
        <h2>{featuredEvent.data.title}</h2>
        <p>{featuredEvent.data.summary}</p>
        <div class="action-row">
          <a class="button button-primary" href={`/events/${featuredEvent.slug}/`}>Event details</a>
          {featuredEvent.data.ticketUrl && <a class="button button-secondary" href={featuredEvent.data.ticketUrl}>Tickets</a>}
        </div>
      </div>
    </section>
  )}

  <section class="section service-section">
    <div class="section-header">
      <p class="eyebrow">What we do</p>
      <h2>Music, community, performance and confidence.</h2>
      <p>VOX is built for people who want community and challenge in the same room.</p>
    </div>
    <div class="service-list">
      <article class="info-card">
        <h3>No auditions</h3>
        <p>You do not need previous choir experience or the ability to read music to get started.</p>
      </article>
      <article class="info-card">
        <h3>Real support</h3>
        <p>Rehearsals are structured, friendly, and designed to help people grow in confidence.</p>
      </article>
      <article class="info-card">
        <h3>Big projects</h3>
        <p>The choir takes on ambitious repertoire, collaborations, and concerts with heart.</p>
      </article>
    </div>
  </section>

  <section class="testimonial-panel">
    <p class="eyebrow">VOX Holloway</p>
    <blockquote>
      “No auditions meant I could just show up. The music is ambitious, but the people make it feel possible.”
    </blockquote>
    <p>Tom, Bass</p>
  </section>

  <section class="logo-strip" aria-label="VOX highlights">
    <span>No auditions</span>
    <span>Open rehearsals</span>
    <span>North London</span>
    <span>Big concerts</span>
    <span>Community voices</span>
  </section>

  <section class="section story-section">
    <div class="section-header">
      <p class="eyebrow">Choir stories</p>
      <h2>What it feels like to join.</h2>
    </div>
    <div class="grid cards">
      {stories.map((story) => (
        <article class="story-card">
          {story.data.image && <img src={story.data.image} alt="" loading="lazy" />}
          <p>"{story.data.quote}"</p>
          <h3>{story.data.name}</h3>
          {story.data.role && <p>{story.data.role}</p>}
          <a href={`/stories/${story.slug}/`}>Read story</a>
        </article>
      ))}
    </div>
    <div class="section-action">
      <a class="button button-secondary" href="/stories/">All choir stories</a>
    </div>
  </section>

  <section class="industries-section">
    <p class="eyebrow">Who we sing with</p>
    <h2>From first-timers to lifelong singers, we make space for different voices.</h2>
    <div class="industry-grid">
      <span>Altos</span>
      <span>Sopranos</span>
      <span>Tenors</span>
      <span>Basses</span>
      <span>New singers</span>
      <span>Returning singers</span>
      <span>Local supporters</span>
      <span>Guest musicians</span>
      <span>Audience members</span>
      <span>Volunteers</span>
      <span>Donors</span>
      <span>Neighbours</span>
    </div>
  </section>
</BaseLayout>
