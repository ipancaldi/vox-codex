---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/EventCard.astro';
import PageHero from '../../components/PageHero.astro';

const events = (await getCollection('events')).sort(
  (a, b) => a.data.date.getTime() - b.data.date.getTime(),
);
---

<BaseLayout title="Events">
  <PageHero
    eyebrow="What's on"
    title="Concerts, open rehearsals, and community nights."
    text="Find the next chance to hear VOX, sing with VOX, or bring friends into the room."
    image="/images/beach-boys.jpg"
  />
  <section class="section section-tight">
    <div class="event-list">
      {events.map((event) => <EventCard event={event} />)}
    </div>
  </section>
</BaseLayout>
