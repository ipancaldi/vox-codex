---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="About">
  <PageHero
    eyebrow="About VOX"
    title="A choir with community at its centre."
    text="VOX Holloway brings people together through generous, ambitious singing in North London."
    image="/images/community-choir.jpg"
  />
  <section class="prose">
    <h1>What VOX stands for</h1>
    <p>VOX is for singers who want warmth and musical ambition in the same place. The choir welcomes people from different backgrounds, levels of experience, and musical confidence.</p>
    <p>The new website is designed to make that welcome visible: clear joining information, current events, stories from members, and simple ways to support the choir.</p>
  </section>
</BaseLayout>
